# Server
ENVIRONMENT=development
CORS_ORIGINS=["http://localhost:3000"]

# Temp storage
TEMP_STORAGE_DIR=/tmp/resume_tailor
TEMP_STORAGE_TTL_SECONDS=600

# NVIDIA NIM
NIM_BASE_URL=https://integrate.api.nvidia.com/v1
USE_MOCK_NIM=false
# Model used only for resume parsing. With deterministic text extraction + a
# leaner prompt, a small fast model suffices. Swap as the NIM catalog changes.
# Other agents use a larger model hardcoded in their agent files.
NIM_PARSER_MODEL=meta/llama-3.1-8b-instruct

# Google OAuth — set in Railway/Vercel env, never commit real values
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/callback
